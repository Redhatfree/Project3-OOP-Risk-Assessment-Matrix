import csv
from datetime import datetime
class Risk:
    def __init__(self, description, probability, impact):
        self.description = description
        self.probability = int(probability)
        self.impact = int(impact)
        self.score = self.probability * self.impact

    def get_severity(self):
        if self.score >= 15:
            return "CRITICAL"
        elif self.score >= 8:
            return "MEDIUM"
        else:
            return "LOW"

    def display_report(self):
        severity = self.get_severity()
        print(f"[{severity:^10}] | Score: {self.score:2} | Risk: {self.description}")

# --- MAIN EXECUTION ---
