import csv
from datetime import datetime

class Risk:
    def __init__(self, description, probability, impact, category):
        self.description = description
        self.probability = int(probability)
        self.impact = int(impact)
        self.score = self.probability * self.impact
        self.category = category.upper()

    def get_severity(self):
        if self.score >= 15: return "CRITICAL"
        elif self.score >= 8: return "MEDIUM"
        else: return "LOW"

    def display_report(self):
        sev = self.get_severity()
        print(f"[{sev:^10}] | {self.category:^12} | Score: {self.score:2} | Risk: {self.description}")

# --- SETUP ---
categories = ["MARKET", "NATURE", "HMS", "TECHNICAL", "INTERFACES"]
risk_registry = []

# Pre-loading (Now with Categories!)
risk_registry.append(Risk("Data Breach", 4, 5, "TECHNICAL"))
risk_registry.append(Risk("Network Latency Issues", 3, 2, "TECHNICAL"))
risk_registry.append(Risk("Database Migration Failure", 2, 5, "TECHNICAL"))
risk_registry.append(Risk("Third-party API Downtime", 5, 3, "INTERFACES"))
risk_registry.append(Risk("Minor UI Bug", 1, 1, "TECHNICAL"))

print("=" * 60)
print("              ENTERPRISE RISK ENTRY SYSTEM              ")
print("=" * 60)

# --- INPUT LOOP ---
while True:
    desc = input("\nRisk Description (or 'quit'): ")
    if desc.lower() == "quit": 
        break
    
    try:
        prob = int(input("Probability (1-5): "))
        imp = int(input("Impact (1-5): "))
        
        # CATEGORY VALIDATION 
        while True:
            cat_input = input(f"Select Category {categories}: ").upper()
            if cat_input in categories:
                cat = cat_input
                break
            else:
                print(f"ERROR: '{cat_input}' is not valid.")

        if 1 <= prob <= 5 and 1 <= imp <= 5:
            risk_registry.append(Risk(desc, prob, imp, cat))
            print("✓ Risk logged.")
        else:
            print("! Error: Please stay between 1 and 5.")
            
    except ValueError:
        print("! Error: Enter whole numbers only.")

# --- DATA ANALYSIS (Calculated once after inputting) ---
risk_registry.sort(key=lambda r: r.score, reverse=True)

all_scores = [r.score for r in risk_registry]
avg_score = sum(all_scores) / len(risk_registry) if risk_registry else 0
critical_ones = [r.description for r in risk_registry if r.get_severity() == "CRITICAL"]

cat_stats = {}
for r in risk_registry:
    cat_stats[r.category] = cat_stats.get(r.category, 0) + 1

# ---  HEATMAP DISPLAY ---
print("\n" + "="*60)
print("            DEPARTMENTAL RISK HEATMAP")
print("="*60)
for c in categories:
    c_scores = [r.score for r in risk_registry if r.category == c]
    if c_scores:
        avg_c = sum(c_scores) / len(c_scores)
        status = "🔴 HIGH" if avg_c > 12 else "🟢 STABLE"
        print(f"{c:12} | Avg Score: {avg_c:4.1f} | Status: {status}")

# --- SEARCH & FILTER MENU ---
while True:
    print("\n" + "-"*30 + "\n      SEARCH & FILTER MENU\n" + "-"*30)
    print("[1] View All | [2] Filter Category | [3] Keyword Search | [4] Export & Exit")
    choice = input("\nSelect: ")

    if choice == "1":
        for r in risk_registry: r.display_report()
    elif choice == "2":
        search_cat = input("Enter Category: ").upper()
        filtered = [r for r in risk_registry if r.category == search_cat]
        for r in filtered: r.display_report()
    elif choice == "3":
        query = input("Keyword: ").lower()
        found = [r for r in risk_registry if query in r.description.lower()]
        for r in found: r.display_report()
    elif choice == "4":
        break

# --- FINAL SUMMARY & EXPORT ---
print("\n" + "=" * 60)
print(f"AVERAGE RISK SCORE: {avg_score:.2f}")
print(f"TOTAL LOGGED: {len(risk_registry)} | CRITICAL: {len(critical_ones)}")
print("=" * 60)

try:
    with open('risk_report.csv', mode='w', newline='') as file:
        writer = csv.writer(file)
        writer.writerow(["Description", "Category", "Score", "Severity"])
        for r in risk_registry:
            writer.writerow([r.description, r.category, r.score, r.get_severity()])
    print(f"\n[SUCCESS] Exported. Breakdown: {cat_stats}")
except Exception as e:
    print(f"\n[ERROR] Could not save file: {e}")
